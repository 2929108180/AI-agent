# ============================================================
# AI PPT Agent — 后端环境变量配置
# Backend Environment Variables Configuration
# ============================================================
# 使用方法 / How to use:
#   1. 复制此文件为 .env / Copy this file as .env
#      cp .env.example .env
#   2. 填入你的真实密钥 / Fill in your real keys
#   3. 启动服务 / Start the server
#      uvicorn app.main:app --reload
# ============================================================


# ────────────────────────────────────────────
# LLM 大模型配置 / LLM Configuration
# ────────────────────────────────────────────

# 选择当前使用的供应商（三选一）
# Choose the active LLM provider (pick one)
#   openai  — GPT-4o 等 OpenAI 模型 / GPT-4o and other OpenAI models
#   grok    — xAI Grok 模型 / xAI Grok models (uses OpenAI-compatible API)
#   gemini  — Google Gemini 模型 / Google Gemini models
LLM_PROVIDER=gemini

# 模型名称 / Model name
#   OpenAI: gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini
#   Grok:   grok-3, grok-3-mini, grok-3-fast
#   Gemini: gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash
LLM_MODEL=gemini-3.1-pro-high

# 生成温度（0-1），越高越有创意，越低越稳定
# Temperature (0-1): higher = more creative, lower = more deterministic
LLM_TEMPERATURE=0.7

# 最大输出 token 数 / Maximum output tokens
LLM_MAX_TOKENS=10000


# ────────────────────────────────────────────
# API 请求地址（中转站 / 代理）
# API Base URL (Proxy / Relay Service)
# ────────────────────────────────────────────
# 如果你使用 API 中转服务（如 one-api、new-api、openrouter 等），
# 请在此填入中转站的地址。留空 = 直连官方 API。
#
# If you use an API relay/proxy service (e.g. one-api, new-api, openrouter),
# set the relay URL here. Leave empty = direct connection to official API.
#
# 示例 / Examples:
#   https://your-relay.com/v1
#   https://openrouter.ai/api/v1
LLM_BASE_URL=http://127.0.0.1:8045/v1


# ────────────────────────────────────────────
# API 密钥 / API Keys
# ────────────────────────────────────────────
# 只需填写你选择的供应商对应的 Key，其余留空即可
# Only fill in the key for your chosen provider, leave others empty

# OpenAI API Key
# 获取地址 / Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# xAI Grok API Key
# 获取地址 / Get it at: https://console.x.ai/
GROK_API_KEY=

# Google Gemini API Key
# 获取地址 / Get it at: https://aistudio.google.com/apikey
GEMINI_API_KEY=sk-6755988626be47c4ad0ed31b9ccf2070


# ────────────────────────────────────────────
# 搜索引擎（轨道 A 背景调研）
# Search Engine (Track A background research)
# ────────────────────────────────────────────
# 默认使用 DuckDuckGo，免费且无需 API Key
# Default: DuckDuckGo — free, no API key required
#
# 如需更高质量结果，可切换为 Serper (Google 搜索代理)
# For higher quality, switch to Serper (Google search proxy)
#   注册地址 / Sign up: https://serper.dev/ （免费额度 2500 次）
#
# 可选值 / Options: duckduckgo | serper
SEARCH_ENGINE=serper

# Serper API Key（仅 SEARCH_ENGINE=serper 时需要）
# Serper API Key (only needed when SEARCH_ENGINE=serper)
SERPER_API_KEY=9e08a7749aba68cde87aef0e44bf0d550a804113


# ────────────────────────────────────────────
# Redis（可选，用于异步任务队列和缓存）
# Redis (optional, for async task queue & caching)
# ────────────────────────────────────────────
# 当前阶段可不配置，后续长链路任务需要
# Not required for now, needed for long-running pipelines later
REDIS_URL=redis://localhost:6379/0


# ────────────────────────────────────────────
# 服务器配置 / Server Configuration
# ────────────────────────────────────────────

# 监听地址 / Listen address
HOST=0.0.0.0

# 端口号 / Port
PORT=8000

# 允许的前端跨域地址（Vite 开发服务器默认 5173）
# Allowed CORS origins (Vite dev server defaults to 5173)
CORS_ORIGINS=["http://localhost:5173"]

# 调试模式 / Debug mode
DEBUG=true
