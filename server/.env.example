# LLM API Keys
OPENAI_API_KEY=sk-xxx
GROK_API_KEY=xai-xxx
GEMINI_API_KEY=AIza-xxx

# LLM Configuration
LLM_PROVIDER=openai          # openai | grok | gemini
LLM_MODEL=gpt-4o             # gpt-4o | grok-3 | gemini-2.5-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Search Engine (Track A)
SEARCH_API_KEY=
SEARCH_ENGINE=bing            # bing | google | serper

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173"]
DEBUG=true
